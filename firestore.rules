rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Permet la lecture à tous, mais l'écriture SEULEMENT à l'admin akwabanewsinfo@gmail.com
    match /settings/global {
      allow read: if true;
      allow write: if request.auth != null && 
                     request.auth.token.email == 'akwabanewsinfo@gmail.com';
    }

    // Règle générale qui refuse toutes les opérations pour tous les autres documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
