rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Règle spécifique pour le document 'settings/global'
    // Permet la lecture à tous, mais l'écriture SEULEMENT à l'admin vérifié
    match /settings/global {
      allow read: if true;
      allow write: if request.auth != null && 
                     request.auth.token.email == 'akwabanewsinfo@gmail.com' && 
                     request.auth.token.email_verified == true;
    }

    // Règle générale qui refuse toutes les opérations pour tous les autres documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
